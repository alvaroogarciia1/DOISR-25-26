        <digimon:hasMemory rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</digimon:hasMemory>
        <digimon:hasSP rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">59</digimon:hasSP>
        <digimon:hasSpeed rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">85</digimon:hasSpeed>
        <digimon:hasStage rdf:resource="https://w3id.org/doisr/group3/digimon#Rookie"/>
        <digimon:learnsSkill rdf:resource="https://w3id.org/doisr/group3/digimon#BabyFlame"/>
    </NamedIndividual>
    


