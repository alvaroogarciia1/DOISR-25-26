    <!-- https://w3id.org/doisr/group3/digimon#Agumon -->


    <NamedIndividual rdf:about="https://w3id.org/doisr/group3/digimon#Agumon">
        <rdf:type rdf:resource="https://w3id.org/doisr/group3/digimon#Digimon"/>
        <rdf:type rdf:resource="https://w3id.org/doisr/group3/digimon#VaccineDigimon"/>
        <rdfs:label>Agumon</rdfs:label>
