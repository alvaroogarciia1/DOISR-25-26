        <digimon:hasAttribute rdf:resource="https://w3id.org/doisr/group3/digimon#Fire"/>
        <digimon:hasDefense rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">80</digimon:hasDefense>
        <digimon:hasHP rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">530</digimon:hasHP>
