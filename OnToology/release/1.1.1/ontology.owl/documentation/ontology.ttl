#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/doisr/group3/digimon#canUseMove
:canUseMove rdf:type owl:ObjectProperty ;
            rdfs:domain :Digimon ;
            rdfs:range :Move ;
            rdfs:comment "Relates a Digimon to a move that it can use."@en ;
            rdfs:label "can use move" .


###  https://w3id.org/doisr/group3/digimon#digivolvesTo
:digivolvesTo rdf:type owl:ObjectProperty ;
              rdfs:domain :Digimon ;
              rdfs:range :Digimon ;
              rdfs:comment "Relates a Digimon to another Digimon into which it can digivolve."@en ;
              rdfs:label "digivolves to" .


###  https://w3id.org/doisr/group3/digimon#hasAttribute
:hasAttribute rdf:type owl:ObjectProperty ;
              rdfs:domain :Digimon ;
              rdfs:range :Attribute ;
              rdfs:comment "Relates a Digimon to its attribute."@en ;
              rdfs:label "has attribute" .


###  https://w3id.org/doisr/group3/digimon#hasMoveType
:hasMoveType rdf:type owl:ObjectProperty ;
             rdfs:domain :Move ;
             rdfs:range :MoveType ;
             rdfs:comment "Relates a move to its move type."@en ;
             rdfs:label "has move type" .


###  https://w3id.org/doisr/group3/digimon#hasRequirement
:hasRequirement rdf:type owl:ObjectProperty ;
                rdfs:domain :Digivolution ;
                rdfs:range :DigivolutionRequirement ;
                rdfs:comment "Relates a digivolution to the requirements needed to perform it."@en ;
                rdfs:label "has requirement" .


###  https://w3id.org/doisr/group3/digimon#hasSourceDigimon
:hasSourceDigimon rdf:type owl:ObjectProperty ;
                  rdfs:domain :Digivolution ;
                  rdfs:range :Digimon ;
                  rdfs:comment "Relates a digivolution to its source Digimon."@en ;
                  rdfs:label "has source digimon" .


###  https://w3id.org/doisr/group3/digimon#hasStage
:hasStage rdf:type owl:ObjectProperty ;
          rdfs:domain :Digimon ;
          rdfs:range :Stage ;
          rdfs:comment "Relates a Digimon to its evolutionary stage."@en ;
          rdfs:label "has stage" .


###  https://w3id.org/doisr/group3/digimon#hasSupportSkill
:hasSupportSkill rdf:type owl:ObjectProperty ;
                 rdfs:domain :Digimon ;
                 rdfs:range :SupportSkill ;
                 rdfs:comment "Relates a Digimon to its support skill."@en ;
                 rdfs:label "has support skill" .


###  https://w3id.org/doisr/group3/digimon#hasTargetDigimon
:hasTargetDigimon rdf:type owl:ObjectProperty ;
                  rdfs:domain :Digivolution ;
                  rdfs:range :Digimon ;
                  rdfs:comment "Relates a digivolution to its target Digimon."@en ;
                  rdfs:label "has target digimon" .


###  https://w3id.org/doisr/group3/digimon#learnsSkill
:learnsSkill rdf:type owl:ObjectProperty ;
             rdfs:domain :Digimon ;
             rdfs:range :Skill ;
             rdfs:comment "Relates a Digimon to a skill that it can learn."@en ;
             rdfs:label "learns skill" .


