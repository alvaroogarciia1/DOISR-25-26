#    Data properties
#################################################################

###  https://w3id.org/doisr/group3/digimon#hasAttack
:hasAttack rdf:type owl:DatatypeProperty ;
           rdfs:domain :Digimon ;
           rdfs:range xsd:integer ;
           rdfs:comment "Represents the attack statistic value of a Digimon."@en ;
           rdfs:label "has attack" .


###  https://w3id.org/doisr/group3/digimon#hasDefense
:hasDefense rdf:type owl:DatatypeProperty ;
            rdfs:domain :Digimon ;
            rdfs:range xsd:integer ;
            rdfs:comment "Represents the defense statistic value of a Digimon."@en ;
            rdfs:label "has defense" .


###  https://w3id.org/doisr/group3/digimon#hasHP
:hasHP rdf:type owl:DatatypeProperty ;
       rdfs:domain :Digimon ;
       rdfs:range xsd:integer ;
       rdfs:comment "Represents the health points value of a Digimon."@en ;
       rdfs:label "has HP" .


###  https://w3id.org/doisr/group3/digimon#hasIntelligence
:hasIntelligence rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Digimon ;
                 rdfs:range xsd:integer ;
                 rdfs:comment "Represents the intelligence statistic value of a Digimon."@en ;
                 rdfs:label "has intelligence" .


###  https://w3id.org/doisr/group3/digimon#hasMemory
:hasMemory rdf:type owl:DatatypeProperty ;
           rdfs:domain :Digimon ;
           rdfs:range xsd:integer ;
           rdfs:comment "Represents the memory cost value of a Digimon."@en ;
           rdfs:label "has memory" .


###  https://w3id.org/doisr/group3/digimon#hasSP
:hasSP rdf:type owl:DatatypeProperty ;
       rdfs:domain :Digimon ;
       rdfs:range xsd:integer ;
       rdfs:comment "Represents the skill points value of a Digimon."@en ;
       rdfs:label "has SP" .


###  https://w3id.org/doisr/group3/digimon#hasSpeed
:hasSpeed rdf:type owl:DatatypeProperty ;
          rdfs:domain :Digimon ;
          rdfs:range xsd:integer ;
          rdfs:comment "Represents the speed statistic value of a Digimon."@en ;
          rdfs:label "has speed" .


#################################################################
#    Classes
#################################################################

###  https://w3id.org/doisr/group3/digimon#Attribute
:Attribute rdf:type owl:Class ;
           rdfs:comment "Represents the elemental or combat attribute associated with a Digimon."@en ;
           rdfs:label "Attribute" .


###  https://w3id.org/doisr/group3/digimon#DataDigimon
:DataDigimon rdf:type owl:Class ;
             rdfs:subClassOf :Digimon ;
             rdfs:comment "A Digimon belonging to the Data type."@en ;
             rdfs:label "Data Digimon" .


###  https://w3id.org/doisr/group3/digimon#Digimon
:Digimon rdf:type owl:Class ;
         rdfs:comment "A digital monster represented in the ontology, described through its stage, attribute, abilities, statistics and digivolution relationships."@en ;
         rdfs:label "Digimon" .


###  https://w3id.org/doisr/group3/digimon#Digivolution
:Digivolution rdf:type owl:Class ;
              rdfs:comment "Represents a digivolution relationship between two Digimon together with its requirements."@en ;
              rdfs:label "Digivolution" .


###  https://w3id.org/doisr/group3/digimon#DigivolutionRequirement
:DigivolutionRequirement rdf:type owl:Class ;
                         rdfs:comment "A requirement that must be satisfied for a Digimon to digivolve."@en ;
                         rdfs:label "Digivolution Requirement" .


###  https://w3id.org/doisr/group3/digimon#FreeDigimon
:FreeDigimon rdf:type owl:Class ;
             rdfs:subClassOf :Digimon ;
             rdfs:comment "A Digimon belonging to the Free type."@en ;
             rdfs:label "Free Digimon" .


###  https://w3id.org/doisr/group3/digimon#Move
:Move rdf:type owl:Class ;
      rdfs:comment "A combat move that can be used by a Digimon."@en ;
      rdfs:label "Move" .


###  https://w3id.org/doisr/group3/digimon#MoveType
:MoveType rdf:type owl:Class ;
          rdfs:comment "Represents the elemental category associated with a move."@en ;
          rdfs:label "Move Type" .


###  https://w3id.org/doisr/group3/digimon#Skill
:Skill rdf:type owl:Class ;
       rdfs:comment "A skill or ability that can be learned by a Digimon."@en ;
       rdfs:label "Skill" .


###  https://w3id.org/doisr/group3/digimon#Stage
:Stage rdf:type owl:Class ;
       rdfs:comment "Represents the evolutionary stage of a Digimon."@en ;
       rdfs:label "Stage" .


###  https://w3id.org/doisr/group3/digimon#SupportSkill
:SupportSkill rdf:type owl:Class ;
              rdfs:subClassOf :Skill ;
              rdfs:comment "A passive support ability associated with a Digimon."@en ;
              rdfs:label "Support Skill" .


###  https://w3id.org/doisr/group3/digimon#VaccineDigimon
:VaccineDigimon rdf:type owl:Class ;
                rdfs:subClassOf :Digimon ;
                rdfs:comment "A Digimon belonging to the Vaccine type."@en ;
                rdfs:label "Vaccine Digimon" .


###  https://w3id.org/doisr/group3/digimon#VirusDigimon
:VirusDigimon rdf:type owl:Class ;
              rdfs:subClassOf :Digimon ;
              rdfs:comment "A Digimon belonging to the Virus type."@en ;
              rdfs:label "Virus Digimon" .


