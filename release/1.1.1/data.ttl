@prefix dig: <https://w3id.org/doisr/group3/digimon#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

#################################################################
# Sample data for SHACL validation of the Digimon ontology
# Group 3 - DOISR 2025-2026
#
# Updated according to ontology version 1.1.0:
# - DigimonType and hasType are no longer used.
# - Digimon types are represented as subclasses of dig:Digimon:
#   dig:VaccineDigimon, dig:VirusDigimon, dig:DataDigimon and dig:FreeDigimon.
# - Attribute values are represented as individuals of dig:Attribute.
#################################################################

#################################################################
# Controlled values used by the sample data
#################################################################

# Stages are kept as individuals of dig:Stage.
dig:Rookie
    a dig:Stage ;
    rdfs:label "Rookie" .

dig:Champion
    a dig:Stage ;
    rdfs:label "Champion" .

# Attribute values are individuals of dig:Attribute.
dig:Fire
    a dig:Attribute ;
    rdfs:label "Fire" .

dig:Neutral
    a dig:Attribute ;
    rdfs:label "Neutral" .

dig:Water
    a dig:Attribute ;
    rdfs:label "Water" .

dig:Plant
    a dig:Attribute ;
    rdfs:label "Plant" .

dig:Earth
    a dig:Attribute ;
    rdfs:label "Earth" .

dig:Wind
    a dig:Attribute ;
    rdfs:label "Wind" .

dig:Electric
    a dig:Attribute ;
    rdfs:label "Electric" .

dig:Light
    a dig:Attribute ;
    rdfs:label "Light" .

dig:Dark
    a dig:Attribute ;
    rdfs:label "Dark" .

# Move types.
dig:Physical
    a dig:MoveType ;
    rdfs:label "Physical" .

dig:Magic
    a dig:MoveType ;
    rdfs:label "Magic" .

#################################################################
# Valid abilities and moves
#################################################################

dig:PepperBreath
    a dig:Move ;
    rdfs:label "Pepper Breath" ;
    dig:hasMoveType dig:Magic ;
    dig:hasPower 65 ;
    dig:hasSPCost 5 .

dig:MegaFlame
    a dig:Move ;
    rdfs:label "Mega Flame" ;
    dig:hasMoveType dig:Magic ;
    dig:hasPower 95 ;
    dig:hasSPCost 10 .

dig:BabyFlame
    a dig:Skill ;
    rdfs:label "Baby Flame" .

dig:AttackCharge
    a dig:SupportSkill ;
    rdfs:label "Attack Charge" .

#################################################################
# Valid Digimon instances
#################################################################

# Agumon is typed both as dig:Digimon and as one of the new type subclasses.
dig:Agumon
    a dig:Digimon, dig:VaccineDigimon ;
    rdfs:label "Agumon" ;
    dig:hasStage dig:Rookie ;
    dig:hasAttribute dig:Fire ;
    dig:hasMemory 5 ;
    dig:hasHP 530 ;
    dig:hasSP 59 ;
    dig:hasAttack 131 ;
    dig:hasDefense 80 ;
    dig:hasIntelligence 70 ;
    dig:hasSpeed 85 ;
    dig:canUseMove dig:PepperBreath ;
    dig:learnsSkill dig:BabyFlame .

dig:Greymon
    a dig:Digimon, dig:VaccineDigimon ;
    rdfs:label "Greymon" ;
    dig:hasStage dig:Champion ;
    dig:hasAttribute dig:Fire ;
    dig:hasMemory 8 ;
    dig:hasHP 700 ;
    dig:hasSP 70 ;
    dig:hasAttack 170 ;
    dig:hasDefense 115 ;
    dig:hasIntelligence 85 ;
    dig:hasSpeed 95 ;
    dig:canUseMove dig:MegaFlame ;
    dig:hasSupportSkill dig:AttackCharge .

#################################################################
# Valid digivolution and requirement
#################################################################

dig:AgumonToGreymon
    a dig:Digivolution ;
    dig:hasSourceDigimon dig:Agumon ;
    dig:hasTargetDigimon dig:Greymon ;
    dig:hasRequirement dig:ReqAgumonToGreymon .

dig:ReqAgumonToGreymon
    a dig:DigivolutionRequirement ;
    rdfs:label "Requirements for Agumon to Greymon" ;
    dig:hasMinLevel 16 ;
    dig:hasMinHP 150 ;
    dig:hasMinAttack 55 ;
    dig:hasMinDefense 40 ;
    dig:hasMinIntelligence 20 ;
    dig:hasMinSpeed 25 .

dig:Agumon
    dig:digivolvesTo dig:Greymon .

#################################################################
# Invalid Digimon examples
#################################################################

# Violates DigimonCoreShape and DigimonStatsShape:
# - empty label;
# - it is typed as dig:Digimon but not as any concrete Digimon type subclass;
# - missing hasAttribute;
# - negative memory;
# - HP is not an integer;
# - negative SP;
# - missing hasAttack;
# - negative hasDefense.
dig:Brokenmon
    a dig:Digimon ;
    rdfs:label "" ;
    dig:hasStage dig:Rookie ;
    dig:hasMemory -1 ;
    dig:hasHP "high" ;
    dig:hasSP -10 ;
    dig:hasDefense -5 ;
    dig:hasIntelligence 40 ;
    dig:hasSpeed 30 ;
    dig:canUseMove dig:PepperBreath .

# Violates DigimonAbilityShape:
# the Digimon has valid core data and stats, but no move, skill or support skill.
dig:NoAbilitymon
    a dig:Digimon, dig:VirusDigimon ;
    rdfs:label "NoAbilitymon" ;
    dig:hasStage dig:Rookie ;
    dig:hasAttribute dig:Neutral ;
    dig:hasMemory 4 ;
    dig:hasHP 400 ;
    dig:hasSP 45 ;
    dig:hasAttack 70 ;
    dig:hasDefense 65 ;
    dig:hasIntelligence 55 ;
    dig:hasSpeed 60 .

#################################################################
# Invalid move and ability examples
#################################################################

# Violates MoveShape:
# - missing rdfs:label;
# - hasMoveType points to an Attribute instead of a MoveType;
# - negative power;
# - SP cost is not an integer.
dig:BrokenMove
    a dig:Move ;
    dig:hasMoveType dig:Fire ;
    dig:hasPower -20 ;
    dig:hasSPCost "many" .

# Violates AbilityLabelShape:
# Skill labels must be non-empty strings.
dig:EmptySkill
    a dig:Skill ;
    rdfs:label "" .

#################################################################
# Invalid digivolution and requirement examples
#################################################################

# Violates DigivolutionShape:
# - source and target are the same Digimon;
# - linked requirement contains invalid values.
dig:InvalidSelfDigivolution
    a dig:Digivolution ;
    dig:hasSourceDigimon dig:Agumon ;
    dig:hasTargetDigimon dig:Agumon ;
    dig:hasRequirement dig:InvalidRequirement .

# Violates DigivolutionRequirementShape:
# - hasMinLevel is negative;
# - hasMinHP is not an integer;
# - hasMinSP is negative;
# - hasMinAttack appears twice;
# - rdfs:comment is not allowed because the shape is closed.
dig:InvalidRequirement
    a dig:DigivolutionRequirement ;
    rdfs:label "Invalid requirement" ;
    rdfs:comment "This property is intentionally not allowed by the closed shape." ;
    dig:hasMinLevel -5 ;
    dig:hasMinHP "a lot" ;
    dig:hasMinSP -1 ;
    dig:hasMinAttack 50, 60 ;
    dig:hasMinDefense 30 ;
    dig:hasMinIntelligence 20 ;
    dig:hasMinSpeed 15 .

# Violates RequirementUsageShape:
# this requirement is not linked from any dig:Digivolution by dig:hasRequirement.
dig:OrphanRequirement
    a dig:DigivolutionRequirement ;
    rdfs:label "Orphan requirement" ;
    dig:hasMinLevel 20 ;
    dig:hasMinAttack 80 .

#################################################################
# Invalid direct digivolvesTo examples
#################################################################

# Violates DigivolvesToShape:
# the object of dig:digivolvesTo is not typed as dig:Digimon.
dig:Agumon
    dig:digivolvesTo dig:NotADigimon .

dig:NotADigimon
    a dig:Move ;
    rdfs:label "This resource is not a Digimon" ;
    dig:hasMoveType dig:Physical ;
    dig:hasPower 10 ;
    dig:hasSPCost 1 .

# Violates DigivolvesToShape:
# the subject of dig:digivolvesTo is not typed as dig:Digimon.
dig:UnknownSource
    dig:digivolvesTo dig:Greymon .
